# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The public URL where the app is hosted.
# Used for Telegram deep links and webhook configuration.
APP_URL="https://habitlink-z4ys.onrender.com"

# TELEGRAM_BOT_TOKEN: Bot token from @BotFather.
# Required for Telegram WebApp initData validation and bot messaging.
TELEGRAM_BOT_TOKEN="YOUR_BOT_TOKEN"

# PORT: Backend server port (default: 8000)
PORT=8000
